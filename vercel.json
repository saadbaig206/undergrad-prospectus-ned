{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/seat_distribution.pdf",
      "destination": "/public/seat_distribution.pdf"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
